<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mega Tech Store | متجر ميجا تك</title>
    <style>
        :root { --primary-pink: #f48fb1; --light-pink: #fce4ec; --dark-gray: #424242; }
        body { font-family: 'Segoe UI', sans-serif; margin: 0; background-color: #ffffff; }
        .top-marquee { background: var(--primary-pink); color: white; padding: 8px 0; text-align: center; font-weight: bold; }
        .utility-bar { display: flex; justify-content: space-between; align-items: center; padding: 15px 5%; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; padding: 20px; }
        .item-card { background: white; border-radius: 15px; padding: 20px; border: 1px solid #fce4ec; text-align: center; }
        .item-card img { width: 100%; height: 160px; object-fit: contain; cursor: pointer; }
        .price { color: #ff4081; font-weight: bold; font-size: 20px; margin: 10px 0; }
        .btn-buy { background: #ff4081; color: white; border: none; padding: 10px 20px; border-radius: 20px; cursor: pointer; }
        .image-lightbox { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 2000; justify-content: center; align-items: center; }
        .image-lightbox img { max-width: 90%; max-height: 80vh; border-radius: 15px; }
    </style>
</head>
<body>

<marquee class="top-marquee">أهلاً بك في متجر Mega Tech - أحدث الأجهزة التقنية!</marquee>

<div class="utility-bar">
    <div style="font-weight: bold; font-size: 20px; color: #ff4081; cursor: pointer;" onclick="location.reload()">Mega Tech 🛍️</div>
    <button onclick="loadWatches()">عرض الساعات الذكية</button>
</div>

<div id="mainContent" class="products-grid">
    </div>

<div id="lightbox" class="image-lightbox" onclick="this.style.display='none'">
    <img id="lightboxImg" src="">
</div>

<script>
const watchProducts = [
    { name: "ساعة RedSport", price: "150 SAR", img: "images/watch1.jpg", desc: "سوار رياضي خفيف" },
    { name: "ساعة Riversong Pro", price: "320 SAR", img: "images/watch2.jpg", desc: "شاشة دائرية متطورة" },
    { name: "ساعة Steel Elite", price: "450 SAR", img: "images/watch3.jpg", desc: "تصميم معدني فاخر" },
    { name: "ساعة Square Watch", price: "280 SAR", img: "images/watch4.jpg", desc: "شاشة مربعة عصرية" },
    { name: "ساعة Earbud Combo", price: "399 SAR", img: "images/watch5.jpg", desc: "سماعات مدمجة" },
    { name: "ساعة 4G Ultra", price: "899 SAR", img: "images/watch6.jpg", desc: "دعم شريحة SIM" },
    { name: "ساعة TWS Hybrid", price: "750 SAR", img: "images/watch7.jpg", desc: "هجين ذكي" },
    { name: "ساعة AMOLED", price: "599 SAR", img: "images/watch8.jpg", desc: "دقة عالية" },
    { name: "ساعة Core Basic", price: "350 SAR", img: "images/watch9.jpg", desc: "تتبع لياقة" },
    { name: "ساعة Apple Style", price: "299 SAR", img: "images/watch10.jpg", desc: "تصميم أنيق" },
    { name: "ساعة Lige Luxury", price: "950 SAR", img: "images/watch11.jpg", desc: "فخامة مطلقة" },
    { name: "ساعة Flash Outdoor", price: "680 SAR", img: "images/watch12.jpg", desc: "مصباح مدمج" },
    { name: "ساعة Ladies Glamour", price: "499 SAR", img: "images/watch13.jpg", desc: "تصميم نسائي" },
    { name: "ساعة Smart V1", price: "410 SAR", img: "images/watch14.jpg", desc: "شاشة مستطيلة" },
    { name: "ساعة Classic Tech", price: "380 SAR", img: "images/watch15.jpg", desc: "تقنية كلاسيكية" }
];

function loadWatches() {
    const container = document.getElementById('mainContent');
    container.innerHTML = "";
    watchProducts.forEach(p => {
        container.innerHTML += `
            <div class="item-card">
                <img src="${p.img}" onclick="openImg('${p.img}')" onerror="this.src='https://via.placeholder.com/150'">
                <h3>${p.name}</h3>
                <p>${p.desc}</p>
                <div class="price">${p.price}</div>
                <button class="btn-buy" onclick="alert('تم الطلب!')">شراء الآن</button>
            </div>
        `;
    });
}

function openImg(src) {
    document.getElementById('lightboxImg').src = src;
    document.getElementById('lightbox').style.display = 'flex';
}
</script>

</body>
</html>
