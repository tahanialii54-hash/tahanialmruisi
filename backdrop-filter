<div id="loginModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeLogin()">&times;</span>
        <h2>تسجيل الدخول</h2>
        <input type="text" placeholder="اسم المستخدم" class="login-input">
        <input type="password" placeholder="كلمة المرور" class="login-input">
        <button class="submit-btn">دخول</button>
    </div>
</div>

<style>
    /* الإعدادات الأساسية */
    .store-container { background: #1a1a1a; min-height: 100vh; color: white; padding: 20px; font-family: sans-serif; }
    
    /* شريط التنقل */
    .glass-navbar { display: flex; justify-content: space-between; align-items: center; padding: 15px; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border-radius: 15px; }
    
    .nav-left { flex: 1; }
    .nav-center { flex: 2; display: flex; justify-content: center; }
    .nav-right { flex: 1; display: flex; justify-content: flex-end; align-items: center; gap: 15px; }

    /* البحث */
    .search-bar { width: 80%; padding: 10px 20px; border-radius: 50px; border: 1px solid #ff69b4; background: #333; color: white; }
    
    /* تسجيل الدخول واليمين */
    .user-area { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .user-img { width: 50px; height: 50px; border-radius: 50%; border: 2px solid #ff69b4; }
    
    /* التواصل */
    .contact-bar { text-align: center; margin: 20px 0; color: #ff69b4; font-weight: bold; }
    .contact-bar a { color: white; text-decoration: none; margin: 0 10px; }

    /* العناصر الأخرى */
    .categories-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    .card { padding: 30px; background: #2a2a2a; border: 1px solid #ff69b4; border-radius: 20px; text-align: center; }
    
    /* نافذة الدخول */
    .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); }
    .modal-content { background: #333; width: 300px; margin: 10% auto; padding: 20px; border-radius: 15px; text-align: center; border: 2px solid #ff69b4; }
    .login-input { width: 90%; padding: 10px; margin: 10px 0; border-radius: 5px; border: none; }
</style>

<script>
    function openLogin() { document.getElementById('loginModal').style.display = 'block'; }
    function closeLogin() { document.getElementById('loginModal').style.display = 'none'; }
</script>