<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>متجر Mega Tech</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 0; background-color: #f9f9f9; }
        nav { text-align: center; padding: 20px; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .btn-nav { padding: 12px 25px; margin: 5px; cursor: pointer; border: none; border-radius: 25px; background: #f48fb1; color: white; font-weight: bold; }
        
        .section { display: none; padding: 40px 5%; }
        .active { display: block; }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }
        .card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); text-align: center; }
        .card img { width: 100%; height: 180px; object-fit: contain; margin-bottom: 15px; }
        .card h3 { color: #ff4081; margin: 10px 0; }
        .price { color: #ff4081; font-weight: bold; font-size: 20px; margin: 10px 0; }
        .btn-buy { background: #ff4081; color: white; border: none; padding: 10px 20px; border-radius: 20px; cursor: pointer; }
    </style>
</head>
<body>

<nav>
    <button class="btn-nav" onclick="showSection('home')">الواجهة</button>
    <button class="btn-nav" onclick="showSection('laptops')">قسم اللابتوبات</button>
    <button class="btn-nav" onclick="showSection('cameras')">قسم الكاميرات</button>
</nav>

<div id="home" class="section active"><h1>مرحباً بك في متجر Mega Tech</h1><p>اختر القسم من الأعلى لتصفح المنتجات.</p></div>

<div id="laptops" class="section"><h2>قسم اللابتوبات</h2><div class="grid"></div></div>

<div id="cameras" class="section">
    <h2>قسم الكاميرات الاحترافية</h2>
    <div id="cameraGrid" class="grid"></div>
</div>

<script>
    const cameraProducts = [
        { name: "Canon EOS 70D", desc: "كاميرا احترافية لأداء مذهل.", price: "650$", img: "c41.jpg" },
        { name: "Sony RX10 IV", desc: "جودة صورة سينمائية وهيكل مدمج.", price: "1,400$", img: "c42.jpg" },
        { name: "Canon EOS 700D", desc: "رفيقك المثالي لاستكشاف التصوير.", price: "420$", img: "c44.jpg" },
        { name: "Nikon Professional", desc: "تحفة تقنية لمحبي الكمال.", price: "980$", img: "c45.jpg" },
        { name: "Canon EOS 2000D", desc: "صور بتفاصيل غنية وألوان حيوية.", price: "390$", img: "c63.jpg" },
        { name: "Canon EOS 60D", desc: "تجمع بين الجمالية والأداء القوي.", price: "450$", img: "c1.jpg" },
        { name: "Canon EOS 5D", desc: "معيار الصناعة للمحترفين.", price: "1,200$", img: "c2.jpg" },
        { name: "Canon EOS 700D Kit", desc: "مناسبة للرحلات والتصوير الخارجي.", price: "350$", img: "c3.jpg" },
        { name: "Nikon D5100", desc: "دقة عالية وأداء مستقر.", price: "380$", img: "c5.jpg" },
        { name: "Canon EOS 600D", desc: "خيار كلاسيكي للتصوير اليومي.", price: "320$", img: "c13.jpg" },
        { name: "Canon White Edition", desc: "إصدار خاص وأناقة لا مثيل لها.", price: "400$", img: "c18.jpg" },
        { name: "Canon EOS 2000D Pro", desc: "كل لقطة ذكرى لا تُنسى.", price: "360$", img: "c19.jpg" },
        { name: "Canon Black Standard", desc: "قوة في الأداء وبساطة في التحكم.", price: "390$", img: "c32.jpg" },
        { name: "Nikon D3300", desc: "معالجة صور سريعة وبطارية قوية.", price: "340$", img: "c36.jpg" },
        { name: "Canon Pop-up Flash", desc: "فلاش مدمج متطور لتوزيع الضوء.", price: "370$", img: "c37.jpg" }
    ];

    function showSection(id) {
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    const grid = document.getElementById('cameraGrid');
    cameraProducts.forEach(p => {
        grid.innerHTML += `
            <div class="card">
                <img src="images/${p.img}" alt="${p.name}" onerror="this.src='https://via.placeholder.com/150'">
                <h3>${p.name}</h3>
                <p>${p.desc}</p>
                <div class="price">${p.price}</div>
                <button class="btn-buy" onclick="alert('تم الطلب: ${p.name}')">طلب الشراء</button>
            </div>
        `;
    });
</script>

</body>
</html>